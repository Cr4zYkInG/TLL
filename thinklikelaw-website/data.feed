			<ukm:DocumentMainType Value="NorthernIrelandStatutoryRule"/><ukm:Year Value="2026"/><ukm:Number Value="20"/><ukm:ISBN Value="9780338025814"/><ukm:CreationDate Date="2026-02-19"/><ukm:Subject Value="RATES"/>
			
			
			<category term="RATES"/>
			<summary>Article 31D of the Rates (Northern Ireland) Order 1977 provides for a rebate on occupied rates for certain retail properties.</summary>
