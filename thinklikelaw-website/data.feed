			<ukm:DocumentMainType Value="NorthernIrelandStatutoryRule"/><ukm:Year Value="2026"/><ukm:Number Value="21"/><ukm:ISBN Value="9780338025821"/><ukm:CreationDate Date="2026-02-19"/><ukm:Subject Value="HEALTH AND PERSONAL SOCIAL SERVICES"/>
			
			
			<category term="HEALTH AND PERSONAL SOCIAL SERVICES"/>
			<summary>These Regulations further amend the Health and Personal Social Services (Optical Charges and Payments) Regulations (Northern Ireland) 1997 (“the principal Regulations”) which provide for payment to be made, by means of a voucher system, in respect of costs incurred by certain categories of persons in connection with the supply, replacement and repair of optical appliances.</summary>
		</entry><entry>
			<id>http://www.legislation.gov.uk/id/nisr/2026/19</id>
			<title>The Rates (Regional Rates) Order (Northern Ireland) 2026</title>
			<link rel="self" href="http://www.legislation.gov.uk/id/nisr/2026/19"/>
			<link href="http://www.legislation.gov.uk/nisr/2026/19/made"/>
			<link rel="alternate" type="application/xml" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.xml" title="XML"/><link rel="alternate" type="application/rdf+xml" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.rdf" title="RDF/XML"/><link rel="alternate" type="application/akn+xml" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.akn" title="AKN"/><link rel="alternate" type="application/xhtml+xml" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.xht" title="HTML snippet"/><link rel="alternate" type="application/akn+xhtml" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.html" title="HTML5"/><link rel="alternate" type="text/html" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.htm" title="Website (XHTML) Default View"/><link rel="alternate" type="text/csv" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.csv" title="CSV"/><link rel="alternate" type="application/pdf" href="http://www.legislation.gov.uk/nisr/2026/19/made/data.pdf" title="PDF"/>
